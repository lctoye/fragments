{
  "name": "fragments",
  "private": true,
  "version": "1.0.0",
  "description": "Fragments back-end API",
  "scripts": {
    "test:integration": "hurl --test --glob \"tests/integration/**/*.hurl\"",
    "test:watch": "jest -c jest.config.js --runInBand --watch --",
    "test": "jest -c jest.config.js --runInBand --",
    "coverage": "jest -c jest.config.js --runInBand --coverage",
    "lint": "eslint --config eslint.config.mjs \"./src/**/*.js\" \"tests/**/*.js\"",
    "start": "node src/index.js",
    "dev": "cross-env LOG_LEVEL=debug nodemon ./src/index.js --watch src",
    "debug": "cross-env LOG_LEVEL=debug nodemon --inspect=0.0.0.0:9229 ./src/index.js --watch src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lctoye/fragments.git"
  },
  "author": "Liam Toye",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "@orangeopensource/hurl": "^7.0.0",
    "eslint": "^9.2.0",
    "globals": "^15.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "3.2.5",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.3",
    "qs": "^6.15.0",
    "tar": "^7.5.10"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1003.0",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/lib-dynamodb": "^3.622.0",
    "aws-jwt-verify": "^4.0.1",
    "compression": "^1.8.1",
    "content-type": "^1.0.5",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "csvtojson": "^2.0.13",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "helmet": "^7.1.0",
    "html-to-text": "^9.0.5",
    "http-auth": "^4.2.0",
    "http-auth-passport": "^1.0.7",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "markdown-to-txt": "^2.0.1",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "pino": "^9.0.0",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.0.0",
    "sharp": "^0.33.4",
    "stoppable": "^1.1.0"
  }
}
